{
  "name": "monarch-kit",
  "version": "0.1.0",
  "description": "Development kit for Monarch ORM",
  "private": false,
  "type": "module",
  "bin": {
    "monarch": "./dist/cli/index.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/lib/index.d.ts",
      "default": "./dist/lib/index.mjs"
    }
  },
  "scripts": {
    "cli:dev": "tsx cli/index.ts",
    "ui:dev": "react-router dev --port 6543",
    "lib:build": "tsdown",
    "ui:build": "react-router build",
    "build": "tsdown && react-router build",
    "start": "node dist/index.js",
    "release": "npm run build && changeset publish",
    "check": "tsc && npm run lint && npm run format && react-router typegen",
    "format": "prettier . --check",
    "format:fix": "prettier . --write",
    "lint": "eslint",
    "lint:fix": "eslint --write",
    "watch": "vitest",
    "test": "vitest run"
  },
  "keywords": [
    "monarch",
    "monarch-orm",
    "mongodb",
    "odm",
    "orm",
    "mongo"
  ],
  "author": "Eric Afes <eriicafes@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eriicafes/monarch-kit.git"
  },
  "bugs": {
    "url": "https://github.com/eriicafes/monarch-kit/issues"
  },
  "homepage": "https://github.com/eriicafes/monarch-kit#readme",
  "peerDependencies": {
    "monarch-orm": ">= 0.11"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@clack/prompts": "^1.2.0",
    "@fontsource-variable/inter": "^5.2.8",
    "@react-router/express": "^8.0.1",
    "@react-router/node": "8.0.1",
    "@react-router/serve": "^8.0.1",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.14.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "1.1.1",
    "commandstruct": "^1.1.2",
    "compression": "^1.8.1",
    "date-fns": "^4.4.0",
    "dotenv": "^17.4.0",
    "express": "^5.2.1",
    "getbox": "^2.0.0",
    "glob": "^13.0.6",
    "hollywood-di": "^0.6.1",
    "isbot": "^5.1.37",
    "jiti": "^2.6.1",
    "lucide-react": "^1.7.0",
    "mongodb": "^7.1.1",
    "morgan": "^1.10.1",
    "react": "^19.2.7",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.7",
    "react-router": "^8.0.1",
    "react-router-action": "^2.0.0",
    "remix-themes": "^2.0.4",
    "shadcn": "^4.1.2",
    "shiki": "^4.2.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "^9.39.4",
    "@react-router/dev": "^8.0.1",
    "@react-router/fs-routes": "^8.0.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "monarch-orm": "^0.11.0",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.2",
    "tsdown": "^0.21.7",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
